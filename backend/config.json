{
  "tools": {
    "brave_api_key": "",
    "allowed_paths": ["~", "/tmp"],
    "denied_write_paths": [
      "~/.ssh",
      "~/.gnupg",
      "~/.bashrc",
      "~/.zshrc",
      "~/.aws",
      "~/voxyflow"
    ],
    "exec_blocklist": [
      "rm -rf /",
      "rm -rf /*",
      "mkfs",
      "dd if=",
      ":(){:|:&};:",
      "chmod -R 777 /",
      "> /dev/sda",
      "mv /* /dev/null"
    ],
    "exec_enabled": true
  }
}
