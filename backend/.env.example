# Voxyflow Configuration
# API keys should be stored via: python setup_keys.py
# These env vars are fallbacks for headless/Docker environments.

# ANTHROPIC_API_KEY=sk-ant-...  # Uncomment for headless environments

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database (SQLite for MVP)
DATABASE_URL=sqlite+aiosqlite:///./voxyflow.db

# Claude Models
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20250315
CLAUDE_OPUS_MODEL=claude-opus-4-20250514
CLAUDE_MAX_TOKENS=1024

# TTS Engine: sherpa-onnx (local CPU) or remote (HTTP endpoint)
TTS_ENGINE=sherpa-onnx
TTS_SERVICE_URL=http://localhost:5500

# STT Engine: browser (Web Speech API, default) or whisper (server-side)
STT_ENGINE=browser
WHISPER_MODEL=turbo

# Voice
VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1

# Conversation tuning
HAIKU_CONTEXT_MESSAGES=20
OPUS_CONTEXT_MESSAGES=100
ANALYZER_ENABLED=true
