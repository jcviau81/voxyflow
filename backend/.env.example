# =============================================================================
# Voxyflow — Environment Configuration
# =============================================================================
# Copy to .env and edit. Only infrastructure config belongs here.
# App preferences (models, TTS, voice, UI) are managed in Settings UI → DB.
#
# Config priority: env vars > .env > defaults in config.py
# =============================================================================

# --- App ---
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Default: ~/.voxyflow/voxyflow.db (created automatically)
# Use an absolute path with 4 slashes after sqlite+aiosqlite:
# DATABASE_URL=sqlite+aiosqlite:////home/youruser/.voxyflow/voxyflow.db

# =============================================================================
# LLM Backend — choose ONE of the three options below
# =============================================================================

# --- Option 1: Claude CLI subprocess (RECOMMENDED) ---
# Uses your Claude Max subscription directly. No API key needed.
# Requires: `claude` CLI installed and authenticated (`claude login`).
CLAUDE_USE_CLI=true
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_DEEP_MODEL=claude-opus-4-7

# --- Option 2: Native Anthropic SDK ---
# Requires an API key. Uncomment and set CLAUDE_USE_CLI=false.
# CLAUDE_USE_NATIVE=true
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# CLAUDE_SONNET_MODEL=claude-sonnet-4-6
# CLAUDE_DEEP_MODEL=claude-opus-4-7

# --- Option 3: OpenAI-compatible proxy (deprecated) ---
# Legacy path. Avoid for new installs.
# CLAUDE_USE_CLI=false
# CLAUDE_USE_NATIVE=false
# CLAUDE_PROXY_URL=http://localhost:3457/v1
# CLAUDE_API_KEY=your-proxy-key-here
