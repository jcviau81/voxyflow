# =============================================================================
# Voxyflow — Environment Configuration
# =============================================================================
# Copy to .env and edit. Only infrastructure config belongs here.
# App preferences (models, TTS, UI) are managed in Settings UI → DB.
#
# Config priority: env vars > .env > defaults in config.py
# =============================================================================

# --- App ---
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Default: ~/.voxyflow/voxyflow.db (created automatically)
# Use an absolute path with 4 slashes after sqlite+aiosqlite:
# DATABASE_URL=sqlite+aiosqlite:////home/youruser/.voxyflow/voxyflow.db

# --- Claude API (via OpenAI-compatible proxy) ---
# CLAUDE_PROXY_URL=http://localhost:3457/v1
# CLAUDE_API_KEY=your-api-key-here

# --- Claude API (native Anthropic SDK — set claude_use_native=true) ---
# CLAUDE_USE_NATIVE=true
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_API_BASE=https://api.anthropic.com

# --- Model overrides (defaults are set in config.py) ---
# CLAUDE_FAST_MODEL=claude-haiku-4-20250514
# CLAUDE_SONNET_MODEL=claude-sonnet-4-20250514
# CLAUDE_DEEP_MODEL=claude-opus-4-20250514
# CLAUDE_MAX_TOKENS=1024

# --- TTS (legacy — now browser-side, kept for compatibility) ---
# TTS_SERVICE_URL=http://localhost:5500
